---
// Saint Messere — index.astro
---
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Saint Messere</title>
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --ink: #e8e4dc;
      --ink-dim: rgba(232,228,220,0.3);
      --ink-ghost: rgba(232,228,220,0.06);
      --bg: #0a0a0a;
      --bg-alt: #0d0d0d;
      --mono: 'Courier New', monospace;
      --serif: 'Georgia', serif;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--ink);
      font-family: var(--serif);
      overflow-x: hidden;
      cursor: none;
    }

    /* ── Cursor ── */
    .cursor {
      width: 8px;
      height: 8px;
      background: var(--ink);
      border-radius: 50%;
      position: fixed;
      pointer-events: none;
      z-index: 9999;
      transform: translate(-50%, -50%);
    }
    .cursor-ring {
      width: 32px;
      height: 32px;
      border: 1px solid rgba(232,228,220,0.35);
      border-radius: 50%;
      position: fixed;
      pointer-events: none;
      z-index: 9998;
      transform: translate(-50%, -50%);
      transition: width 0.2s, height 0.2s, border-color 0.2s;
    }
    body:has(a:hover) .cursor-ring {
      width: 48px;
      height: 48px;
      border-color: rgba(232,228,220,0.6);
    }

    /* ── Noise ── */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 1;
      opacity: 0.03;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    }

    /* ── Sections ── */
    section {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 80px 60px;
      position: relative;
      overflow: hidden;
    }

    /* ── Parallax ghost chars ── */
    .ghost {
      position: absolute;
      font-family: var(--serif);
      font-style: italic;
      color: var(--ink-ghost);
      pointer-events: none;
      user-select: none;
      will-change: transform;
      line-height: 1;
    }

    /* ── Reveal system ── */
    [data-reveal] {
      opacity: 0;
      transition: opacity 0.9s ease, transform 0.9s ease;
    }
    [data-reveal="up"]    { transform: translateY(40px); }
    [data-reveal="left"]  { transform: translateX(-60px); }
    [data-reveal="scale"] { transform: scale(0.92); }
    [data-reveal="fade"]  { transform: none; }
    [data-reveal].visible { opacity: 1; transform: none; }

    /* ── HERO ── */
    .hero {
      flex-direction: column;
      text-align: center;
      background: var(--bg);
      gap: 0;
    }
    .hero-eyebrow {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.35em;
      color: var(--ink-dim);
      text-transform: uppercase;
      margin-bottom: 48px;
      transition-delay: 0s;
    }
    .hero-name {
      font-size: clamp(64px, 13vw, 148px);
      font-weight: 400;
      line-height: 0.88;
      letter-spacing: -0.02em;
      transition-delay: 0.15s;
    }
    .hero-name .light { color: rgba(232,228,220,0.18); font-style: italic; }
    .hero-sub {
      margin-top: 48px;
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.25em;
      color: var(--ink-dim);
      transition-delay: 0.3s;
    }
    .scroll-hint {
      position: absolute;
      bottom: 40px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 10px;
      opacity: 0;
      animation: fadeIn 1s ease 1.2s forwards;
    }
    .scroll-hint span {
      font-family: var(--mono);
      font-size: 9px;
      letter-spacing: 0.35em;
      color: rgba(232,228,220,0.2);
      text-transform: uppercase;
    }
    .scroll-hint::after {
      content: '';
      width: 1px;
      height: 56px;
      background: linear-gradient(to bottom, rgba(232,228,220,0.25), transparent);
      animation: scrollPulse 2.2s ease infinite;
    }
    @keyframes fadeIn { to { opacity: 1; } }
    @keyframes scrollPulse {
      0%   { transform: scaleY(0); transform-origin: top; opacity: 1; }
      49%  { transform: scaleY(1); transform-origin: top; opacity: 1; }
      50%  { transform: scaleY(1); transform-origin: bottom; opacity: 1; }
      100% { transform: scaleY(0); transform-origin: bottom; opacity: 0; }
    }

    /* ── MANIFESTO ── */
    .manifesto {
      background: var(--bg-alt);
      flex-direction: column;
    }
    .manifesto-wrap { max-width: 640px; width: 100%; }
    .m-line {
      font-size: clamp(26px, 4vw, 46px);
      font-weight: 400;
      line-height: 1.15;
      padding-bottom: 18px;
      margin-bottom: 18px;
      border-bottom: 1px solid var(--ink-ghost);
    }
    .m-line:last-child { border-bottom: none; }
    .m-em   { color: var(--ink); }
    .m-dim  { color: rgba(232,228,220,0.2); }
    .m-mid  { color: rgba(232,228,220,0.55); }
    .m-italic { font-style: italic; font-size: clamp(14px, 2vw, 20px); color: rgba(232,228,220,0.3); }

    /* ── PILLARS ── */
    .pillars {
      background: var(--bg);
      flex-direction: column;
      gap: 72px;
    }
    .pillars-label {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.45em;
      color: rgba(232,228,220,0.2);
      text-transform: uppercase;
    }
    .pillars-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: rgba(232,228,220,0.07);
      width: 100%;
      max-width: 900px;
    }
    .pillar {
      background: var(--bg);
      padding: 48px 32px;
      transition: background 0.3s ease, opacity 0.9s ease, transform 0.9s ease;
    }
    .pillar:hover { background: #111; }
    .pillar-num {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.2em;
      color: rgba(232,228,220,0.18);
      margin-bottom: 24px;
    }
    .pillar h3 {
      font-size: 22px;
      font-weight: 400;
      margin-bottom: 18px;
      line-height: 1.2;
    }
    .pillar p {
      font-family: var(--mono);
      font-size: 11px;
      color: rgba(232,228,220,0.32);
      line-height: 1.9;
      letter-spacing: 0.04em;
    }

    /* ── TEATRO ── */
    .teatro {
      background: var(--bg-alt);
      flex-direction: column;
      text-align: center;
      gap: 64px;
    }
    .teatro h2 {
      font-size: clamp(38px, 7vw, 84px);
      font-weight: 400;
      letter-spacing: -0.02em;
      line-height: 1.05;
    }
    .teatro h2 em { font-style: italic; color: rgba(232,228,220,0.28); }
    .acts {
      display: flex;
      align-items: center;
      gap: 48px;
    }
    .act { display: flex; flex-direction: column; align-items: center; gap: 14px; }
    .act-symbol {
      font-size: 28px;
      opacity: 0.5;
      line-height: 1;
    }
    .act-label {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.3em;
      color: rgba(232,228,220,0.28);
      text-transform: uppercase;
    }
    .act-sep {
      font-size: 16px;
      color: rgba(232,228,220,0.1);
      padding-bottom: 20px;
    }

    /* ── CIERRE ── */
    .cierre {
      background: var(--bg);
      flex-direction: column;
      text-align: center;
      gap: 36px;
    }
    .cierre-quote {
      font-size: clamp(17px, 2.8vw, 30px);
      font-style: italic;
      color: rgba(232,228,220,0.45);
      max-width: 560px;
      line-height: 1.6;
    }
    .cierre-quote strong { color: var(--ink); font-weight: 400; }
    .cierre-sig {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.3em;
      color: rgba(232,228,220,0.18);
    }
    .cierre-links {
      display: flex;
      gap: 48px;
      justify-content: center;
      margin-top: 16px;
    }
    .cierre-link {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: rgba(232,228,220,0.35);
      text-decoration: none;
      padding-bottom: 4px;
      border-bottom: 1px solid rgba(232,228,220,0.12);
      transition: color 0.3s, border-color 0.3s;
    }
    .cierre-link:hover { color: var(--ink); border-color: rgba(232,228,220,0.5); }

    /* ── Responsive ── */
    @media (max-width: 720px) {
      section { padding: 60px 28px; }
      .pillars-grid { grid-template-columns: 1fr; }
      .acts { flex-direction: column; gap: 28px; }
      .act-sep { transform: rotate(90deg); }
      .cierre-links { gap: 28px; }
    }
  </style>
</head>
<body>

  <div class="cursor" id="cursor"></div>
  <div class="cursor-ring" id="cursorRing"></div>

  <!-- ── HERO ── -->
  <section class="hero">
    <div class="ghost" style="font-size:clamp(160px,28vw,320px);top:-8%;right:-4%;" data-speed="0.28">S</div>
    <div class="ghost" style="font-size:clamp(120px,22vw,260px);bottom:-12%;left:-6%;" data-speed="0.16">M</div>

    <p class="hero-eyebrow" data-reveal="up">Un universo en construcción lenta</p>
    <h1 class="hero-name" data-reveal="up">
      <span class="light">Saint</span><br>
      Messere
    </h1>
    <p class="hero-sub" data-reveal="up">Teatro · Personaje · Círculo</p>

    <div class="scroll-hint">
      <span>Desplaza</span>
    </div>
  </section>

  <!-- ── MANIFESTO ── -->
  <section class="manifesto">
    <div class="ghost" style="font-size:clamp(100px,18vw,200px);top:15%;right:2%;" data-speed="0.2">∞</div>
    <div class="manifesto-wrap">
      <p class="m-line m-em"    data-reveal="left" data-delay="0">No persuade.</p>
      <p class="m-line m-dim"   data-reveal="left" data-delay="80">No explica.</p>
      <p class="m-line m-em"    data-reveal="left" data-delay="160">No vende.</p>
      <p class="m-line m-mid"   data-reveal="left" data-delay="240">Insinúa. Provoca. Atrae.</p>
      <p class="m-line m-italic" data-reveal="left" data-delay="340">"El universo se construye lento.<br>Primero la familia, luego el mito."</p>
    </div>
  </section>

  <!-- ── PILLARS ── -->
  <section class="pillars">
    <p class="pillars-label" data-reveal="fade">El sistema</p>
    <div class="pillars-grid">
      <div class="pillar" data-reveal="up" data-delay="0">
        <div class="pillar-num">01</div>
        <h3>El personaje</h3>
        <p>Satírico pero preciso.<br>Elegante pero callejero.<br>Un narrador que juega.</p>
      </div>
      <div class="pillar" data-reveal="up" data-delay="120">
        <div class="pillar-num">02</div>
        <h3>El teatro</h3>
        <p>Cada acto es una escena.<br>Cada visita es participar.<br>No se observa — se habita.</p>
      </div>
      <div class="pillar" data-reveal="up" data-delay="240">
        <div class="pillar-num">03</div>
        <h3>El círculo</h3>
        <p>No busca audiencia.<br>Construye familia.<br>Por afinidad, no algoritmo.</p>
      </div>
    </div>
  </section>

  <!-- ── TEATRO ── -->
  <section class="teatro">
    <div class="ghost" style="font-size:clamp(120px,20vw,220px);top:8%;left:-2%;" data-speed="0.22">T</div>
    <h2 data-reveal="scale">
      El <em>teatro</em><br>de Saint Messere
    </h2>
    <div class="acts" data-reveal="up" data-delay="150">
      <div class="act">
        <div class="act-symbol">◯</div>
        <div class="act-label">Interacción</div>
      </div>
      <div class="act-sep">→</div>
      <div class="act">
        <div class="act-symbol">◈</div>
        <div class="act-label">Interpretación</div>
      </div>
      <div class="act-sep">→</div>
      <div class="act">
        <div class="act-symbol">◉</div>
        <div class="act-label">Participación</div>
      </div>
    </div>
  </section>

  <!-- ── CIERRE ── -->
  <section class="cierre">
    <p class="cierre-quote" data-reveal="up">
      Un universo narrativo íntimo donde el lenguaje,<br>la estética y el silencio generan una experiencia<br>que mezcla <strong>arte, seducción y pensamiento.</strong>
    </p>
    <p class="cierre-sig" data-reveal="fade" data-delay="200">— Saint Messere</p>
    <nav class="cierre-links" data-reveal="up" data-delay="350">
      <a href="https://on.soundcloud.com/dXyF4x4jJx3oxKWEZS" target="_blank" class="cierre-link">Audition</a>
      <a href="/gallery" class="cierre-link">Gallery</a>
      <a href="https://instagram.com/saintmessere" target="_blank" class="cierre-link">Instagram</a>
    </nav>
  </section>

  <script>
    // ── Cursor
    const cursor = document.getElementById('cursor');
    const ring   = document.getElementById('cursorRing');
    let mx = 0, my = 0, rx = 0, ry = 0;

    document.addEventListener('mousemove', e => {
      mx = e.clientX; my = e.clientY;
      cursor.style.left = mx + 'px';
      cursor.style.top  = my + 'px';
    });

    (function animRing() {
      rx += (mx - rx) * 0.1;
      ry += (my - ry) * 0.1;
      ring.style.left = rx + 'px';
      ring.style.top  = ry + 'px';
      requestAnimationFrame(animRing);
    })();

    // ── Parallax ghost chars
    const ghosts = document.querySelectorAll('.ghost[data-speed]');
    window.addEventListener('scroll', () => {
      const sy = window.scrollY;
      ghosts.forEach(el => {
        el.style.transform = `translateY(${sy * parseFloat(el.dataset.speed)}px)`;
      });
    }, { passive: true });

    // ── Reveal on scroll
    const reveals = document.querySelectorAll('[data-reveal]');
    const obs = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const delay = parseInt(entry.target.dataset.delay || 0);
        setTimeout(() => entry.target.classList.add('visible'), delay);
        obs.unobserve(entry.target);
      });
    }, { threshold: 0.12 });

    reveals.forEach(el => obs.observe(el));

    // ── Hero auto-reveal on load
    document.querySelectorAll('.hero [data-reveal]').forEach((el, i) => {
      setTimeout(() => el.classList.add('visible'), 300 + i * 180);
    });
  </script>

</body>
</html>
