---
// index.astro - Insecto Digital Homepage — v7 (breathing effect integrado)
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Insecto Digital — Hub Creativo</title>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --negro: #080808; --verde: #BCFF47; --magenta: #FF3CAC;
      --cyan: #2AFADF; --naranja: #FF6B2B; --violeta: #9B5DFF;
      --blanco: #F5F0E8;
    }

    body {
      background: var(--negro);
      color: var(--blanco);
      overflow-x: hidden;
    }

    /* HERO */
    .hero {
      min-height: 100vh;
      position: relative;
      overflow: hidden;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
    }

    /* 🔥 BLOBS (GRÁFICAS GRANDES) */
    .blob {
      position: absolute;
      border-radius: 50%;
      filter: blur(80px);
      opacity: .18;

      /* 👇 DOS ANIMACIONES COMBINADAS */
      animation:
        float 8s ease-in-out infinite,
        breathing 6s ease-in-out infinite;
    }

    .blob-1 {
      width:600px;height:600px;
      background:var(--verde);
      top:-100px;right:-100px;
      animation-duration: 8s, 6.2s;
      animation-delay: 0s, 0s;
    }

    .blob-2 {
      width:400px;height:400px;
      background:var(--magenta);
      bottom:100px;left:10%;
      animation-duration: 9s, 7s;
      animation-delay: -3s, 2s;
    }

    .blob-3 {
      width:300px;height:300px;
      background:var(--cyan);
      top:30%;left:40%;
      animation-duration: 7s, 5.5s;
      animation-delay: -6s, 4s;
    }

    .blob-4 {
      width:250px;height:250px;
      background:var(--violeta);
      top:60%;right:20%;
      animation-duration: 8.5s, 6.8s;
      animation-delay: -4s, 1.5s;
    }

    /* 🌊 MOVIMIENTO ORIGINAL */
    @keyframes float {
      0%,100% { transform: translate(0,0) scale(1); }
      33% { transform: translate(30px,-20px) scale(1.05); }
      66% { transform: translate(-20px,15px) scale(.95); }
    }

    /* 🫁 RESPIRACIÓN NATURAL (COLOR + INTENSIDAD) */
    @keyframes breathing {
      0% {
        filter: blur(80px) brightness(0.85) saturate(0.9);
        opacity: 0.16;
      }

      50% {
        filter: blur(90px) brightness(1.2) saturate(1.25);
        opacity: 0.22;
      }

      100% {
        filter: blur(80px) brightness(0.85) saturate(0.9);
        opacity: 0.16;
      }
    }

  </style>
</head>

<body>

  <section class="hero">
    <div class="hero-bg">
      <div class="blob blob-1"></div>
      <div class="blob blob-2"></div>
      <div class="blob blob-3"></div>
      <div class="blob blob-4"></div>
    </div>
  </section>

</body>
</html>